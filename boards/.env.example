# Soleil Boards — client build env (Vite). Copy to `.env.local` for local dev.
# Only VITE_* vars are inlined into the client bundle at build time. The Sentry
# auth-token vars at the bottom are build-time-only (used by vite.config.js to
# upload source maps) and are NOT exposed to the client.

# Supabase (public-by-design; gated by RLS, not secrecy).
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Legacy fallback (older deploys): VITE_SUPABASE_ANON_KEY

# PartyKit realtime transport. After `npm run deploy:party`, point HOST at the
# deployed URL (no protocol) and flip USE_PARTYKIT=true.
VITE_USE_PARTYKIT=true
VITE_PARTYKIT_HOST=<name>.<account>.partykit.dev

# Cloudflare Web Analytics beacon token (cookieless pageviews). Optional —
# unset = beacon skipped.
# VITE_CF_ANALYTICS_TOKEN=

# Optional build/release tag stamped onto first-party client error logs
# (public.client_errors). e.g. a short git SHA injected by the build.
# VITE_RELEASE=
