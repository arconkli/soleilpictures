# Board generator secrets/config. Copy to scripts/.env and fill in.
# scripts/.env is git-ignored — never commit real keys.

# Supabase (service_role bypasses RLS for the showcase workspace writes)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Cloudflare R2 S3 API (same values the Worker/party use for soleil-boards-images)
R2_ACCOUNT_ID=<cf-account-id>
R2_BUCKET=soleil-boards-images
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>

# Where seeded boards live. Use a dedicated "showcase" workspace owned by an
# admin account so they don't clutter a real user. SEED_USER_ID is the created_by
# (an admin user's UUID). SEED_PARENT_BOARD_ID is optional (defaults to root).
SEED_WORKSPACE_ID=<workspace-uuid>
SEED_USER_ID=<admin-user-uuid>
# SEED_PARENT_BOARD_ID=<optional-parent-board-uuid>

# Image source API keys (free tiers)
UNSPLASH_ACCESS_KEY=<unsplash-access-key>
PEXELS_API_KEY=<pexels-api-key>

# Optional
SITE_ORIGIN=https://clusters.soleilpictures.com
# INDEXNOW_KEY=a7f3c1e94b8d4f26a0e5c7d213b6f80a
